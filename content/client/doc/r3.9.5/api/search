udit-logs#four-letter-words","content":"See the Four Letter Words section in the Administrator's Guide."},"871":{"id":"/admin-ops/monitor-and-audit-logs-41","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Apache ZooKeeper supports audit logging from version 3.6.0. By default audit logs are disabled.\nTo enable them, set audit.enable=true in conf/zoo.cfg. Audit logs are not written on every\nZooKeeper server — they are written only on the servers to which a client is connected, as\nillustrated below."},"872":{"id":"/admin-ops/monitor-and-audit-logs-42","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"The audit log captures detailed information for audited operations, written as key=value pairs:"},"873":{"id":"/admin-ops/monitor-and-audit-logs-43","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Key"},"874":{"id":"/admin-ops/monitor-and-audit-logs-44","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Value"},"875":{"id":"/admin-ops/monitor-and-audit-logs-45","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"session"},"876":{"id":"/admin-ops/monitor-and-audit-logs-46","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Client session ID."},"877":{"id":"/admin-ops/monitor-and-audit-logs-47","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"user"},"878":{"id":"/admin-ops/monitor-and-audit-logs-48","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Comma-separated list of users associated with the client session. See Who is taken as user in audit logs?"},"879":{"id":"/admin-ops/monitor-and-audit-logs-49","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"ip"},"880":{"id":"/admin-ops/monitor-and-audit-logs-50","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Client IP address."},"881":{"id":"/admin-ops/monitor-and-audit-logs-51","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"operation"},"882":{"id":"/admin-ops/monitor-and-audit-logs-52","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"The audited operation. Possible values: serverStart, serverStop, create, delete, setData, setAcl, multiOperation, reconfig, ephemeralZNodeDeleteOnSessionClose."},"883":{"id":"/admin-ops/monitor-and-audit-logs-53","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"znode"},"884":{"id":"/admin-ops/monitor-and-audit-logs-54","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Path of the znode."},"885":{"id":"/admin-ops/monitor-and-audit-logs-55","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"znode type"},"886":{"id":"/admin-ops/monitor-and-audit-logs-56","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Type of the znode (only for create operations)."},"887":{"id":"/admin-ops/monitor-and-audit-logs-57","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"acl"},"888":{"id":"/admin-ops/monitor-and-audit-logs-58","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"String representation of the znode ACL, e.g. cdrwa (create, delete, read, write, admin). Only logged for setAcl."},"889":{"id":"/admin-ops/monitor-and-audit-logs-59","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"result"},"890":{"id":"/admin-ops/monitor-and-audit-logs-60","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Outcome of the operation: success, failure, or invoked. The invoked result is used for serverStop because the stop is logged before the server has confirmed it actually stopped."},"891":{"id":"/admin-ops/monitor-and-audit-logs-61","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-logs","content":"Sample audit logs for all operations, where the client connected from 192.168.1.2, client\nprincipal is zkcli@HADOOP.COM, and server principal is zookeeper/192.168.1.3@HADOOP.COM:"},"892":{"id":"/admin-ops/monitor-and-audit-logs-62","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-log-configuration","content":"Audit logging is performed using Logback. The following is the default logback configuration\nblock in conf/logback.xml (the entire block is commented out by default — uncomment it to\nactivate audit logging):"},"893":{"id":"/admin-ops/monitor-and-audit-logs-63","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#audit-log-configuration","content":"Modify this configuration to customize the audit log filename, number of backup files,\nmaximum file size, or to use a custom audit logger."},"894":{"id":"/admin-ops/monitor-and-audit-logs-64","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"There are four built-in authentication providers:"},"895":{"id":"/admin-ops/monitor-and-audit-logs-65","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"IPAuthenticationProvider — the authenticated IP address is used as the user."},"896":{"id":"/admin-ops/monitor-and-audit-logs-66","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"SASLAuthenticationProvider — the client principal is used as the user."},"897":{"id":"/admin-ops/monitor-and-audit-logs-67","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"X509AuthenticationProvider — the client certificate is used as the user."},"898":{"id":"/admin-ops/monitor-and-audit-logs-68","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"DigestAuthenticationProvider — the authenticated username is used as the user."},"899":{"id":"/admin-ops/monitor-and-audit-logs-69","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"Custom authentication providers can override org.apache.zookeeper.server.auth.AuthenticationProvider.getUserName(String id)\nto provide a user name. If a custom provider does not override this method, the value stored in\norg.apache.zookeeper.data.Id.id is used as the user. Generally only the user name is stored in\nthis field, but it is up to the custom provider what they store there."},"900":{"id":"/admin-ops/monitor-and-audit-logs-70","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"Not all ZooKeeper operations are initiated by clients — some are performed by the server itself.\nFor example, when a client session closes, any ephemeral znodes it owned are deleted by the server\ndirectly. These are called system operations. For system operations, the user associated with the\nZooKeeper server principal is logged as the user. For example, if the server principal is\nzookeeper/hadoop.hadoop.com@HADOOP.COM, it becomes the system user:"},"901":{"id":"/admin-ops/monitor-and-audit-logs-71","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"If there is no user associated with the ZooKeeper server, the OS user who started the server\nprocess is used. For example, if the server was started by root:"},"902":{"id":"/admin-ops/monitor-and-audit-logs-72","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#who-is-taken-as-user-in-audit-logs","content":"A single client can attach multiple authentication schemes to a session. In that case all\nauthenticated identities are taken as the user and presented as a comma-separated list. For\nexample, if a client is authenticated with principal zkcli@HADOOP.COM and IP 127.0.0.1,\nthe create operation audit log will be:"},"903":{"id":"/admin-ops/observers-guide","page_id":"/admin-ops/observers-guide","type":"page","content":"Observers","breadcrumbs":["Multi-Page Documentation","Admin & Ops"],"tags":[],"url":"/admin-ops/observers-guide"},"904":{"id":"/admin-ops/observers-guide-0","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide","content":"How ZooKeeper Observers enable scaling to large numbers of clients without hurting write performance, by using non-voting ensemble members that can be added freely without affecting quorum."},"905":{"id":"/admin-ops/observers-guide-1","page_id":"/admin-ops/observers-guide","type":"heading","tags":[],"url":"/admin-ops/observers-guide#how-to-use-observers","content":"How to Use Observers"},"906":{"id":"/admin-ops/observers-guide-2","page_id":"/admin-ops/observers-guide","type":"heading","tags":[],"url":"/admin-ops/observers-guide#how-to-use-observer-masters","content":"How to Use Observer Masters"},"907":{"id":"/admin-ops/observers-guide-3","page_id":"/admin-ops/observers-guide","type":"heading","tags":[],"url":"/admin-ops/observers-guide#example-use-cases","content":"Example Use Cases"},"908":{"id":"/admin-ops/observers-guide-4","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide","content":"Although ZooKeeper performs very well by having clients connect directly\nto voting members of the ensemble, this architecture makes it hard to\nscale out to huge numbers of clients. The problem is that as we add more\nvoting members, write performance drops. This is because a write operation\nrequires the agreement of at least half the nodes in an ensemble, so the\ncost of a vote grows significantly as more voters are added."},"909":{"id":"/admin-ops/observers-guide-5","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide","content":"We have introduced a new type of ZooKeeper node called an Observer which\nhelps address this problem and further improves ZooKeeper's scalability. Observers\nare non-voting members of an ensemble which only hear the results of votes, not the\nagreement protocol that leads up to them. Other than this simple distinction,\nObservers function exactly the same as Followers — clients may connect to\nthem and send read and write requests to them. Observers forward these\nrequests to the Leader like Followers do, but they then simply wait to\nhear the result of the vote. Because of this, we can increase the number\nof Observers as much as we like without harming vote performance."},"910":{"id":"/admin-ops/observers-guide-6","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide","content":"Observers have other advantages. Because they do not vote, they are not a\ncritical part of the ZooKeeper ensemble — they can fail or be\ndisconnected from the cluster without harming the availability of the\nZooKeeper service. The benefit to the user is that Observers may connect\nover less reliable network links than Followers. In fact, Observers may be\nused to talk to a ZooKeeper server from another data center. Clients of\nan Observer will see fast reads, as all reads are served locally, and\nwrites result in minimal network traffic since the number of messages\nrequired without the vote protocol is smaller."},"911":{"id":"/admin-ops/observers-guide-7","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observers","content":"Setting up a ZooKeeper ensemble that uses Observers requires just two\nchanges to your config files."},"912":{"id":"/admin-ops/observers-guide-8","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observers","content":"First, in the config file of every node that is to be an Observer, add:"},"913":{"id":"/admin-ops/observers-guide-9","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observers","content":"This tells ZooKeeper that the server is to be an Observer."},"914":{"id":"/admin-ops/observers-guide-10","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observers","content":"Second, in every server config file, append :observer to the server\ndefinition line of each Observer. For example:"},"915":{"id":"/admin-ops/observers-guide-11","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observers","content":"This tells every other server that server.1 is an Observer and that they\nshould not expect it to vote. This is all the configuration needed to add\nan Observer to your ZooKeeper cluster. You can then connect to it as you\nwould an ordinary Follower:"},"916":{"id":"/admin-ops/observers-guide-12","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observers","content":"where localhost:2181 is the hostname and port of the Observer as\nspecified in every config file. You should see a command line prompt\nthrough which you can issue commands like ls to query the ZooKeeper service."},"917":{"id":"/admin-ops/observers-guide-13","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observer-masters","content":"Observers function simply as non-voting members of the ensemble, sharing\nthe Learner interface with Followers and holding only a slightly different\ninternal pipeline. Both maintain connections along the quorum port with the\nLeader by which they learn of all new proposals on the ensemble."},"918":{"id":"/admin-ops/observers-guide-14","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observer-masters","content":"By default, Observers connect to the Leader along its quorum port to learn of\nnew proposals. There are benefits to allowing Observers to connect to\nFollowers instead as a means of plugging into the commit stream. This shifts\nthe burden of supporting Observers off the Leader, allowing it to focus on\ncoordinating the commit of writes. The result is better performance when the\nLeader is under high load — particularly high network load such as after a\nleader election when many Learners need to sync. It also reduces the total\nnumber of network connections maintained on the Leader when there are many\nObservers. Activating this feature allows the overall number of Observers to\nscale into the hundreds, and improves Observer availability since a large\nnumber of Observers finish syncing and start serving client traffic faster."},"919":{"id":"/admin-ops/observers-guide-15","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#how-to-use-observer-masters","content":"This feature is activated by adding the following entry to the server config\nfile. It instructs Observers to connect to peers (Leaders and Followers) on\nthe specified port, and instructs Followers to create an ObserverMaster thread\nto listen and serve on that port:"},"920":{"id":"/admin-ops/observers-guide-16","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#example-use-cases","content":"Wherever you wish to scale the number of clients of your ZooKeeper ensemble,\nor where you wish to insulate the critical part of an ensemble from the load\nof dealing with client requests, Observers are a good architectural choice.\nTwo example use cases are:"},"921":{"id":"/admin-ops/observers-guide-17","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#example-use-cases","content":"Datacenter bridge: Forming a ZooKeeper ensemble between two datacenters is\nproblematic because high variance in latency between datacenters can lead to\nfalse-positive failure detection and partitioning. However, if the ensemble runs\nentirely in one datacenter and the second datacenter runs only Observers,\npartitions are not problematic — the ensemble remains connected. Clients of the\nObservers may still see and issue proposals."},"922":{"id":"/admin-ops/observers-guide-18","page_id":"/admin-ops/observers-guide","tags":[],"type":"text","url":"/admin-ops/observers-guide#example-use-cases","content":"Message bus integration: Some use cases call for ZooKeeper as a component of\na persistent reliable message bus. Observers provide a natural integration point:\na plug-in mechanism can attach the stream of proposals an Observer sees to a\npublish-subscribe system, without loading the core ensemble."},"923":{"id":"/admin-ops/quorums","page_id":"/admin-ops/quorums","type":"page","content":"Quorums","breadcrumbs":["Multi-Page Documentation","Admin & Ops"],"tags":[],"url":"/admin-ops/quorums"},"924":{"id":"/admin-ops/quorums-0","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums","content":"How to configure ZooKeeper quorums: hierarchical quorums using server groups and weights, and Oracle Quorum for increasing availability in two-instance clusters."},"925":{"id":"/admin-ops/quorums-1","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#hierarchical-quorums","content":"Hierarchical Quorums"},"926":{"id":"/admin-ops/quorums-2","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#oracle-quorum","content":"Oracle Quorum"},"927":{"id":"/admin-ops/quorums-3","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#the-implementation-of-the-oracle","content":"The Implementation of the Oracle"},"928":{"id":"/admin-ops/quorums-4","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#deployment-contexts","content":"Deployment Contexts"},"929":{"id":"/admin-ops/quorums-5","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#configuring-the-oracle-in-zoocfg","content":"Configuring the Oracle in zoo.cfg"},"930":{"id":"/admin-ops/quorums-6","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#example-zoocfg","content":"Example zoo.cfg"},"931":{"id":"/admin-ops/quorums-7","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#behavior-after-enabling-the-oracle","content":"Behavior After Enabling the Oracle"},"932":{"id":"/admin-ops/quorums-8","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#considerations-when-using-the-oracle","content":"Considerations When Using the Oracle"},"933":{"id":"/admin-ops/quorums-9","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#liveness-issue","content":"Liveness Issue"},"934":{"id":"/admin-ops/quorums-10","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#safety-issue","content":"Safety Issue"},"935":{"id":"/admin-ops/quorums-11","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#examples-of-failure-detector-implementations","content":"Examples of Failure Detector Implementations"},"936":{"id":"/admin-ops/quorums-12","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#hardware-based-implementation","content":"Hardware-based Implementation"},"937":{"id":"/admin-ops/quorums-13","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#software-based-implementation","content":"Software-based Implementation"},"938":{"id":"/admin-ops/quorums-14","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Using a USB Device as the Oracle"},"939":{"id":"/admin-ops/quorums-15","page_id":"/admin-ops/quorums","type":"heading","tags":[],"url":"/admin-ops/quorums#reference","content":"Reference"},"940":{"id":"/admin-ops/quorums-16","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#hierarchical-quorums","content":"This document gives an example of how to use hierarchical quorums. The basic idea is\nvery simple. First, we split servers into groups, and add a line for each group listing\nthe servers that form this group. Next we have to assign a weight to each server."},"941":{"id":"/admin-ops/quorums-17","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#hierarchical-quorums","content":"The following example shows how to configure a system with three groups of three servers\neach, and we assign a weight of 1 to each server:"},"942":{"id":"/admin-ops/quorums-18","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#hierarchical-quorums","content":"When running the system, we are able to form a quorum once we have a majority of votes from\na majority of non-zero-weight groups. Groups that have zero weight are discarded and not\nconsidered when forming quorums. Looking at the example, we are able to form a quorum once\nwe have votes from at least two servers from each of two different groups."},"943":{"id":"/admin-ops/quorums-19","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#oracle-quorum","content":"Oracle Quorum increases the availability of a cluster of 2 ZooKeeper instances with a failure detector known as the Oracle.\nThe Oracle is designed to grant permission to the instance which is the only remaining instance\nin a 2-instance configuration when the other instance is identified as faulty by the failure detector."},"944":{"id":"/admin-ops/quorums-20","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#the-implementation-of-the-oracle","content":"Every instance accesses a file which contains either 0 or 1 to indicate whether that instance is authorized by the Oracle.\nThis design can be changed since failure detector algorithms vary. You can override the askOracle() method in QuorumOracleMaj to adapt a preferred way of reading the Oracle's decision."},"945":{"id":"/admin-ops/quorums-21","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#deployment-contexts","content":"The Oracle is designed to increase the availability of a cluster of 2 ZooKeeper instances; thus, the size of the voting member is 2.\nIn other words, the Oracle solves the consensus problem of a possible faulty instance in a two-instance ensemble."},"946":{"id":"/admin-ops/quorums-22","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#deployment-contexts","content":"When the size of the voting members exceeds 2, the expected way to make the Oracle work correctly is to reconfigure the cluster size when a faulty machine is identified.\nFor example, with a configuration of 5 instances, when a faulty machine breaks the connection with the Leader, a reconfig client request is expected to re-form the cluster as 4 instances.\nOnce the size of the voting member equals 2, the configuration falls into the problem domain which the Oracle is designed to address."},"947":{"id":"/admin-ops/quorums-23","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#configuring-the-oracle-in-zoocfg","content":"Regardless of the cluster size, oraclePath must be configured at initialization time, like other static parameters.\nThe following shows the correct way to specify and enable the Oracle:"},"948":{"id":"/admin-ops/quorums-24","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#configuring-the-oracle-in-zoocfg","content":"QuorumOracleMaj reads the result of a failure detector written to a text file — the oracle file.\nSuppose you have the result of the failure detector written to /some/path/result.txt; the correct configuration is:"},"949":{"id":"/admin-ops/quorums-25","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#configuring-the-oracle-in-zoocfg","content":"The oracle file should contain 1 to authorize the instance, or 0 to deny it. An example file can be created with:"},"950":{"id":"/admin-ops/quorums-26","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#configuring-the-oracle-in-zoocfg","content":"Any equivalent file is suitable for the current implementation of QuorumOracleMaj.\nThe number of oracle files should equal the number of ZooKeeper instances configured to enable the Oracle.\nEach ZooKeeper instance should have its own oracle file — files must not be shared, otherwise the issues described in the Safety section will arise."},"951":{"id":"/admin-ops/quorums-27","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#behavior-after-enabling-the-oracle","content":"QuorumPeerConfig will create an instance of QuorumOracleMaj instead of the default QuorumMaj when it reads an oraclePath in zoo.cfg.\nQuorumOracleMaj inherits from QuorumMaj and differs from its superclass by overriding containsQuorum().\nQuorumOracleMaj executes its version of containsQuorum when the Leader loses all of its followers and fails to maintain the quorum.\nIn all other cases, QuorumOracleMaj behaves identically to QuorumMaj."},"952":{"id":"/admin-ops/quorums-28","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#considerations-when-using-the-oracle","content":"We consider an asynchronous distributed system which consists of 2 ZooKeeper instances and an Oracle."},"953":{"id":"/admin-ops/quorums-29","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#liveness-issue","content":"When the Oracle satisfies the following property introduced by :"},"954":{"id":"/admin-ops/quorums-30","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#liveness-issue","content":"Strong Completeness: There is a time after which every process that crashes is permanently suspected by every correct process."},"955":{"id":"/admin-ops/quorums-31","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#liveness-issue","content":"Liveness of the system is ensured by the Oracle.\nHowever, when the Oracle fails to maintain this property, loss of liveness is expected. For example:"},"956":{"id":"/admin-ops/quorums-32","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#liveness-issue","content":"Suppose we have a Leader and a Follower running in the broadcasting state. The system will lose its liveness when:"},"957":{"id":"/admin-ops/quorums-33","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#liveness-issue","content":"The Leader fails, but the Oracle does not detect the faulty Leader — the Oracle will not authorize the Follower to become a new Leader."},"958":{"id":"/admin-ops/quorums-34","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#liveness-issue","content":"A Follower fails, but the Oracle does not detect the faulty Follower — the Oracle will authorize the Leader to move the system forward."},"959":{"id":"/admin-ops/quorums-35","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Loss of Progress"},"960":{"id":"/admin-ops/quorums-36","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Progress can be lost when multiple failures occur in the system at different times. For example:"},"961":{"id":"/admin-ops/quorums-37","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Suppose we have a Leader (Ben) and a Follower (John) in the broadcasting state:"},"962":{"id":"/admin-ops/quorums-38","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"T1 zxid(0x1_1): L-Ben fails, and F-John takes over under authorization from the Oracle."},"963":{"id":"/admin-ops/quorums-39","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"T2 zxid(0x2_1): F-John becomes a new Leader (L-John) and starts a new epoch."},"964":{"id":"/admin-ops/quorums-40","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"T3 zxid(0x2_A): L-John fails."},"965":{"id":"/admin-ops/quorums-41","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"T4 zxid(0x2_A): Ben recovers and starts leader election."},"966":{"id":"/admin-ops/quorums-42","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"T5 zxid(0x3_1): Ben becomes the new Leader (L-Ben) under authorization from the Oracle."},"967":{"id":"/admin-ops/quorums-43","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"In this case, the system loses its progress after L-Ben initially failed."},"968":{"id":"/admin-ops/quorums-44","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"However, loss of progress can be prevented by making the Oracle capable of referring to the latest zxid.\nWhen the Oracle can refer to the latest zxid, at T5 zxid(0x2_A), Ben will not complete leader election because the Oracle would not authorize him while John is still known to be ahead.\nThis trades liveness for safety."},"969":{"id":"/admin-ops/quorums-45","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Split Brain Issue"},"970":{"id":"/admin-ops/quorums-46","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"We consider the Oracle satisfies the following property introduced by :"},"971":{"id":"/admin-ops/quorums-47","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Accuracy: There is a time after which some correct process is never suspected by any process."},"972":{"id":"/admin-ops/quorums-48","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"The decisions the Oracle gives out must be mutually exclusive."},"973":{"id":"/admin-ops/quorums-49","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Suppose we have a Leader (Ben) and a Follower (John) in the broadcasting state:"},"974":{"id":"/admin-ops/quorums-50","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"At any time, the Oracle will not authorize both Ben and John simultaneously, even if each failure detector suspects the other."},"975":{"id":"/admin-ops/quorums-51","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Equivalently: for any two Oracle files, their values must not both be 1 at the same time."},"976":{"id":"/admin-ops/quorums-52","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"Split brain is expected when the Oracle fails to maintain this property during leader election, which can happen at:"},"977":{"id":"/admin-ops/quorums-53","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"System start."},"978":{"id":"/admin-ops/quorums-54","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#safety-issue","content":"A failed instance recovering from failure."},"979":{"id":"/admin-ops/quorums-55","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#examples-of-failure-detector-implementations","content":"A failure detector's role is to authorize the querying ZooKeeper instance whether it has the right to move the system forward without waiting for the faulty instance."},"980":{"id":"/admin-ops/quorums-56","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#hardware-based-implementation","content":"Suppose two dedicated hardware nodes, hw1 and hw2, host ZooKeeper instances zk1 and zk2 respectively, forming a cluster.\nA hardware device attached to both nodes can determine whether each is powered on.\nWhen hw1 is not powered on, zk1 is undoubtedly faulty.\nThe hardware device then updates the oracle file on hw2 to 1, authorizing zk2 to move the system forward."},"981":{"id":"/admin-ops/quorums-57","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#software-based-implementation","content":"Suppose two dedicated hardware nodes, hw1 and hw2, host ZooKeeper instances zk1 and zk2 respectively.\nTwo services, o1 on hw1 and o2 on hw2, detect whether the other node is alive (for example, by pinging).\nWhen o1 cannot ping hw2, it identifies hw2 as faulty and updates the oracle file of zk1 to 1, authorizing zk1 to move forward."},"982":{"id":"/admin-ops/quorums-58","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"In macOS 10.15.7 (19H2), external storage devices are mounted under /Volumes.\nA USB device containing the required oracle file can serve as the Oracle.\nWhen the device is connected, the oracle authorizes the leader to move the system forward."},"983":{"id":"/admin-ops/quorums-59","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"The following 6 steps demonstrate how this works:"},"984":{"id":"/admin-ops/quorums-60","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Insert a USB device named Oracle. The path /Volumes/Oracle will be accessible."},"985":{"id":"/admin-ops/quorums-61","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Create a file containing 1 under /Volumes/Oracle named mastership:"},"986":{"id":"/admin-ops/quorums-62","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"The path /Volumes/Oracle/mastership is now accessible to ZooKeeper instances."},"987":{"id":"/admin-ops/quorums-63","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Create a zoo.cfg like the following:"},"988":{"id":"/admin-ops/quorums-64","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Note: Split brain will not occur here because there is only a single USB device. mastership must not be shared by multiple instances — only one ZooKeeper instance should be configured with Oracle. See the Safety Issue section for details."},"989":{"id":"/admin-ops/quorums-65","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Start the cluster. It should form a quorum normally."},"990":{"id":"/admin-ops/quorums-66","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Terminate the instance that is either not attached to a USB device or whose mastership file contains 0. Two scenarios are expected:"},"991":{"id":"/admin-ops/quorums-67","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"A leader failure occurs, and the remaining instance completes leader election on its own via the Oracle."},"992":{"id":"/admin-ops/quorums-68","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"The quorum is maintained via the Oracle."},"993":{"id":"/admin-ops/quorums-69","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"Remove the USB device. /Volumes/Oracle/mastership becomes unavailable. According to the current implementation, whenever the Leader queries the oracle and the file is missing, the oracle throws an exception and returns false. Repeating step 5 will result in either the system being unable to recover from a leader failure, or the leader losing the quorum and service being interrupted."},"994":{"id":"/admin-ops/quorums-70","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#using-a-usb-device-as-the-oracle","content":"With these steps, you can observe and practice how the Oracle works with a two-instance system."},"995":{"id":"/admin-ops/quorums-71","page_id":"/admin-ops/quorums","tags":[],"type":"text","url":"/admin-ops/quorums#reference","content":"Tushar Deepak Chandra and Sam Toueg. 1991. Unreliable failure detectors for asynchronous systems (preliminary version). In Proceedings of the tenth annual ACM symposium on Principles of distributed computing (PODC '91). Association for Computing Machinery, New York, NY, USA, 325–340. DOI:10.1145/112600.112627"},"996":{"id":"/admin-ops/quota-guide","page_id":"/admin-ops/quota-guide","type":"page","content":"Quota Guide","breadcrumbs":["Multi-Page Documentation","Admin & Ops"],"tags":[],"url":"/admin-ops/quota-guide"},"997":{"id":"/admin-ops/quota-guide-0","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide","content":"ZooKeeper has both namespace and bytes quotas. You can use the ZooKeeperMain class to setup quotas."},"998":{"id":"/admin-ops/quota-guide-1","page_id":"/admin-ops/quota-guide","type":"heading","tags":[],"url":"/admin-ops/quota-guide#setting-quotas","content":"Setting Quotas"},"999":{"id":"/admin-ops/quota-guide-2","page_id":"/admin-ops/quota-guide","type":"heading","tags":[],"url":"/admin-ops/quota-guide#listing-quotas","content":"Listing Quotas"},"1000":{"id":"/admin-ops/quota-guide-3","page_id":"/admin-ops/quota-guide","type":"heading","tags":[],"url":"/admin-ops/quota-guide#deleting-quotas","content":"Deleting Quotas"},"1001":{"id":"/admin-ops/quota-guide-4","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide","content":"ZooKeeper prints WARN messages if users exceed the quota assigned to them. The messages\nare printed in the log of the ZooKeeper."},"1002":{"id":"/admin-ops/quota-guide-5","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide","content":"Notice: What the namespace quota means is the count quota which limits the number of children\nunder the path (included itself)."},"1003":{"id":"/admin-ops/quota-guide-6","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide","content":"The above command gives you a command line option of using quotas."},"1004":{"id":"/admin-ops/quota-guide-7","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"You can use setquota to set a quota on a ZooKeeper node. It has an option of setting quota with\n-n (for namespace/count) and -b (for bytes/data length)."},"1005":{"id":"/admin-ops/quota-guide-8","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"The ZooKeeper quota is stored in ZooKeeper itself in /zookeeper/quota. To disable other people from\nchanging the quotas, users can set the ACL for /zookeeper/quota so that only admins are able to read and write to it."},"1006":{"id":"/admin-ops/quota-guide-9","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"If the quota doesn't exist in the specified path, create the quota, otherwise update the quota."},"1007":{"id":"/admin-ops/quota-guide-10","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"The scope of the quota users set is all the nodes under the path specified (included itself)."},"1008":{"id":"/admin-ops/quota-guide-11","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"In order to simplify the calculation of quota in the current directory/hierarchy structure, a complete\ntree path (from root to leaf node) can be set only one quota. In the situation when setting a quota in\na path which its parent or child node already has a quota, setquota will reject and tell the specified\nparent or child path. Users can adjust allocations of quotas (delete/move-up/move-down the quota)\naccording to specific circumstances."},"1009":{"id":"/admin-ops/quota-guide-12","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"Combined with the Chroot, the quota will have a better isolation effectiveness between different\napplications. For example:"},"1010":{"id":"/admin-ops/quota-guide-13","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"Users cannot set the quota on the path under /zookeeper/quota."},"1011":{"id":"/admin-ops/quota-guide-14","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#setting-quotas","content":"The quota supports soft and hard quotas. The soft quota just logs a warning when exceeding the quota,\nbut the hard quota also throws a QuotaExceededException. When setting soft and hard quota on the same\npath, the hard quota has priority."},"1012":{"id":"/admin-ops/quota-guide-15","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#listing-quotas","content":"You can use listquota to list a quota on a ZooKeeper node."},"1013":{"id":"/admin-ops/quota-guide-16","page_id":"/admin-ops/quota-guide","tags":[],"type":"text","url":"/admin-ops/quota-guide#deleting-quotas","content":"You can use delquota to delete quota on a ZooKeeper node."},"1014":{"id":"/admin-ops/snapshot-and-restore-guide","page_id":"/admin-ops/snapshot-and-restore-guide","type":"page","content":"Snapshot and Restore Guide","breadcrumbs":["Multi-Page Documentation","Admin & Ops"],"tags":[],"url":"/admin-ops/snapshot-and-restore-guide"},"1015":{"id":"/admin-ops/snapshot-and-restore-guide-0","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide","content":"How to use ZooKeeper's snapshot and restore APIs to recover a cluster from quorum loss or catastrophic failure."},"1016":{"id":"/admin-ops/snapshot-and-restore-guide-1","page_id":"/admin-ops/snapshot-and-restore-guide","type":"heading","tags":[],"url":"/admin-ops/snapshot-and-restore-guide#snapshot","content":"Snapshot"},"1017":{"id":"/admin-ops/snapshot-and-restore-guide-2","page_id":"/admin-ops/snapshot-and-restore-guide","type":"heading","tags":[],"url":"/admin-ops/snapshot-and-restore-guide#restore","content":"Restore"},"1018":{"id":"/admin-ops/snapshot-and-restore-guide-3","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide","content":"ZooKeeper is designed to withstand machine failures. A ZooKeeper cluster can automatically recover\nfrom temporary failures such as machine reboots, and can tolerate up to (N-1)/2 permanent failures\nfor a cluster of N members due to hardware failures or disk corruption. When a member permanently\nfails, it loses access to the cluster. If the cluster permanently loses more than (N-1)/2 members,\nit disastrously fails and loses quorum. Once quorum is lost, the cluster cannot reach consensus and\ntherefore cannot continue to accept updates."},"1019":{"id":"/admin-ops/snapshot-and-restore-guide-4","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide","content":"To recover from such disastrous failures, ZooKeeper provides snapshot and restore functionalities to\nrestore a cluster from a snapshot."},"1020":{"id":"/admin-ops/snapshot-and-restore-guide-5","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide","content":"Key characteristics of snapshot and restore:"},"1021":{"id":"/admin-ops/snapshot-and-restore-guide-6","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide","content":"They operate on the connected server via Admin Server APIs."},"1022":{"id":"/admin-ops/snapshot-and-restore-guide-7","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide","content":"They are rate-limited to protect the server from being overloaded."},"1023":{"id":"/admin-ops/snapshot-and-restore-guide-8","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide","content":"They require authentication and authorization on the root path with ALL permission. The supported\nauth schemes are digest, x509, and IP."},"1024":{"id":"/admin-ops/snapshot-and-restore-guide-9","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide#snapshot","content":"Recovering a cluster needs a snapshot from a ZooKeeper cluster. Users can periodically take\nsnapshots from a live server which has the highest zxid and stream out data to local or external\nstorage/file system (e.g., S3)."},"1025":{"id":"/admin-ops/snapshot-and-restore-guide-10","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide#restore","content":"Restoring a cluster needs a single snapshot as input stream. Restore can be used for recovering a\ncluster after quorum loss or for building a brand-new cluster with seed data."},"1026":{"id":"/admin-ops/snapshot-and-restore-guide-11","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide#restore","content":"All members should restore using the same snapshot. The recommended steps are:"},"1027":{"id":"/admin-ops/snapshot-and-restore-guide-12","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide#restore","content":"Take a snapshot of the latest database state using the snapshot admin server command, if\napplicable."},"1028":{"id":"/admin-ops/snapshot-and-restore-guide-13","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide#restore","content":"For each server:"},"1029":{"id":"/admin-ops/snapshot-and-restore-guide-14","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide#restore","content":"Move the files in dataDir and dataLogDir to a different location to prevent the restored\ndatabase from being overwritten when the server restarts after restore."},"1030":{"id":"/admin-ops/snapshot-and-restore-guide-15","page_id":"/admin-ops/snapshot-and-restore-guide","tags":[],"type":"text","url":"/admin-ops/snapshot-and-restore-guide#restore","content":"Restore the server using the restore admin server command:"},"1031":{"id":"/admin-ops/tools","page_id":"/admin-ops/tools","type":"page","content":"Tools","breadcrumbs":["Multi-Page Documentation","Admin & Ops"],"tags":[],"url":"/admin-ops/tools"},"1032":{"id":"/admin-ops/tools-0","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools","content":"Reference for the scripts and tools bundled with ZooKeeper — including server management scripts, snapshot and transaction log utilities, benchmark tools, and testing frameworks."},"1033":{"id":"/admin-ops/tools-1","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#scripts","content":"Scripts"},"1034":{"id":"/admin-ops/tools-2","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zkserversh","content":"zkServer.sh"},"1035":{"id":"/admin-ops/tools-3","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zkclish","content":"zkCli.sh"},"1036":{"id":"/admin-ops/tools-4","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zkenvsh","content":"zkEnv.sh"},"1037":{"id":"/admin-ops/tools-5","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zkcleanupsh","content":"zkCleanup.sh"},"1038":{"id":"/admin-ops/tools-6","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"zkTxnLogToolkit.sh"},"1039":{"id":"/admin-ops/tools-7","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zksnapshottoolkitsh","content":"zkSnapShotToolkit.sh"},"1040":{"id":"/admin-ops/tools-8","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zksnapshotrecursivesummarytoolkitsh","content":"zkSnapshotRecursiveSummaryToolkit.sh"},"1041":{"id":"/admin-ops/tools-9","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zksnapshotcomparersh","content":"zkSnapshotComparer.sh"},"1042":{"id":"/admin-ops/tools-10","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#locating-snapshots","content":"Locating Snapshots"},"1043":{"id":"/admin-ops/tools-11","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#supported-snapshot-formats","content":"Supported Snapshot Formats"},"1044":{"id":"/admin-ops/tools-12","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#running-the-tool","content":"Running the Tool"},"1045":{"id":"/admin-ops/tools-13","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#interactive-mode","content":"Interactive Mode"},"1046":{"id":"/admin-ops/tools-14","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#benchmark","content":"Benchmark"},"1047":{"id":"/admin-ops/tools-15","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#ycsb","content":"YCSB"},"1048":{"id":"/admin-ops/tools-16","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#zk-smoketest","content":"zk-smoketest"},"1049":{"id":"/admin-ops/tools-17","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#testing","content":"Testing"},"1050":{"id":"/admin-ops/tools-18","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#fault-injection-framework","content":"Fault Injection Framework"},"1051":{"id":"/admin-ops/tools-19","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#byteman","content":"Byteman"},"1052":{"id":"/admin-ops/tools-20","page_id":"/admin-ops/tools","type":"heading","tags":[],"url":"/admin-ops/tools#jepsen-test","content":"Jepsen Test"},"1053":{"id":"/admin-ops/tools-21","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zkserversh","content":"Manage the ZooKeeper server process."},"1054":{"id":"/admin-ops/tools-22","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zkserversh","content":"The status command establishes a client connection to execute diagnostic commands.\nWhen the ZooKeeper cluster is started in TLS-only mode (by omitting clientPort from\nzoo.cfg), additional SSL configuration must be provided:"},"1055":{"id":"/admin-ops/tools-23","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zkclish","content":"See ZooKeeper CLI."},"1056":{"id":"/admin-ops/tools-24","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zkenvsh","content":"Sets environment variables for the ZooKeeper server. Key variables:"},"1057":{"id":"/admin-ops/tools-25","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zkenvsh","content":"ZOO_LOG_DIR — the directory where logs are stored."},"1058":{"id":"/admin-ops/tools-26","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zkcleanupsh","content":"Clean up old snapshots and transaction logs."},"1059":{"id":"/admin-ops/tools-27","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"Dump and recover transaction log files with broken CRC entries."},"1060":{"id":"/admin-ops/tools-28","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"The default behavior is safe — it dumps the entries of the given transaction log file\nto the screen (same as -d,--dump):"},"1061":{"id":"/admin-ops/tools-29","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"In recovery mode (-r,--recover), the original file is left untouched and all transactions\nare copied to a new file with a .fixed suffix. CRC values are recalculated; if the calculated\nvalue does not match the original, the new value is used. By default the tool is interactive,\nasking for confirmation on each CRC error:"},"1062":{"id":"/admin-ops/tools-30","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"Yes — write the recalculated CRC to the new file."},"1063":{"id":"/admin-ops/tools-31","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"No — copy the original CRC value."},"1064":{"id":"/admin-ops/tools-32","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"Abort — abort the operation. The .fixed file will not be deleted and may be in a half-complete state."},"1065":{"id":"/admin-ops/tools-33","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zktxnlogtoolkitsh","content":"Use -v,--verbose to print all records (not just broken ones). Use -y,--yes to fix all\nCRC errors automatically without prompting."},"1066":{"id":"/admin-ops/tools-34","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zksnapshottoolkitsh","content":"Dump a snapshot file to stdout, showing detailed information for each znode."},"1067":{"id":"/admin-ops/tools-35","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zksnapshotrecursivesummarytoolkitsh","content":"Recursively collect and display child count and data size for a selected node."},"1068":{"id":"/admin-ops/tools-36","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zksnapshotcomparersh","content":"Compare two snapshots with configurable thresholds and filters, outputting the delta —\nwhich znodes were added, updated, or deleted. Useful for offline consistency checks and\ndata trend analysis. Only permanent nodes are reported; sessions and ephemeral nodes are ignored."},"1069":{"id":"/admin-ops/tools-37","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zksnapshotcomparersh","content":"Tuning parameters:"},"1070":{"id":"/admin-ops/tools-38","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zksnapshotcomparersh","content":"--nodes — threshold for number of descendant nodes added/removed."},"1071":{"id":"/admin-ops/tools-39","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#zksnapshotcomparersh","content":"--bytes — threshold for bytes added/removed."},"1072":{"id":"/admin-ops/tools-40","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#locating-snapshots","content":"Snapshots are stored in the ZooKeeper data directory\nconfigured in conf/zoo.cfg."},"1073":{"id":"/admin-ops/tools-41","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#supported-snapshot-formats","content":"Uncompressed snapshots and compressed formats (snappy, gz) are all supported.\nSnapshots in different formats can be compared directly without manual decompression."},"1074":{"id":"/admin-ops/tools-42","page_id":"/admin-ops/tools","tags":[],"type":"text","url":"/admin-ops/tools#running-the-tool","content":"Running the tool with no 