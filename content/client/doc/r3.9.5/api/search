DEBUG and confirm these entries appear in the logs:"},"857":{"id":"/admin-ops/monitor-and-audit-logs-27","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#prometheus","content":"Prometheus is the easiest way to ingest and record ZooKeeper metrics."},"858":{"id":"/admin-ops/monitor-and-audit-logs-28","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#prometheus","content":"Install Prometheus from the official download page."},"859":{"id":"/admin-ops/monitor-and-audit-logs-29","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#prometheus","content":"Configure the scraper to target your ZooKeeper cluster endpoints:"},"860":{"id":"/admin-ops/monitor-and-audit-logs-30","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#prometheus","content":"Start Prometheus:"},"861":{"id":"/admin-ops/monitor-and-audit-logs-31","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#prometheus","content":"Prometheus will now scrape ZooKeeper metrics every 10 seconds."},"862":{"id":"/admin-ops/monitor-and-audit-logs-32","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#alerting-with-prometheus","content":"Read the Prometheus alerting documentation\nfor alerting principles, and use Prometheus Alertmanager\nto receive alert notifications via email or webhook."},"863":{"id":"/admin-ops/monitor-and-audit-logs-33","page_id":"/admin-ops/monitor-and-audit-logs","tags":[],"type":"text","url":"/admin-ops/monitor-and-audit-logs#alerting-with-prometheus","content":"The following is a reference alerting rules file for common ZooKeeper metrics. Adjust\nthresholds to match your environment."},"864":{"id":"/admin-ops/monitor-and-audit-logs-34","page_id"